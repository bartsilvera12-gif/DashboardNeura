# Copia a .env.local y rellena las claves desde tu Supabase self-hosted (Studio / Kong > API).
# URL pública de la API (sin barra final recomendada).

NEXT_PUBLIC_SUPABASE_URL=https://api.neura.com.py
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Schema de negocio (PostgREST / supabase-js .schema())
NEXT_PUBLIC_BUSINESS_SCHEMA=tradexpar
PUBLIC_API_ALLOWED_ORIGIN=https://app.lovable.dev

# URL pública de esta app Next (sin barra final). Obligatoria para enlaces de pago y documentación API.
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# Opcional: conexión directa PostgreSQL (scripts reporte-db, migraciones con pg)
# SUPABASE_DB_URL=postgresql://postgres:PASSWORD@host:5432/postgres
